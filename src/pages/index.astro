---
import Layout from '../layouts/Layout.astro';
import ItemTable from '../components/ItemTable.astro';
import ItemModal from '../components/ItemModal.astro';
import itemsData from '../data/items.json';

const items = itemsData as any[];
---
<Layout>
  {items.length === 0 ? (
    <div style="max-width:600px; margin:4rem auto; padding:2rem; text-align:center; color:var(--text-muted);">
      <p style="font-size:1.2rem; margin-bottom:1rem;">⚠ Dati non ancora generati</p>
      <p>Esporta l'Excel come CSV, salvalo in <code style="color:var(--accent)">src/data/items.csv</code>, poi esegui:</p>
      <pre style="background:var(--bg-raised); border:1px solid var(--border); border-radius:6px; padding:1rem; margin:1rem 0; text-align:left; font-size:0.85rem;">npm run fetch-data</pre>
      <p>Poi riavvia il dev server.</p>
    </div>
  ) : (
    <ItemTable items={items} />
  )}
  <ItemModal />
</Layout>

<script src="../scripts/table.js"></script>
<script src="../scripts/modal.js"></script>
