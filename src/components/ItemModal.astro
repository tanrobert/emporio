<!-- Modal overlay — content injected by modal.js -->
<div
  id="modal-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  hidden
>
  <div id="modal-content">
    <button id="modal-close" aria-label="Chiudi">✕</button>

    <div id="modal-header">
      <h2 id="modal-title"></h2>
      <div id="modal-meta"></div>
    </div>

    <div id="modal-body">
      <div id="modal-prices" class="price-grid"></div>
      <div id="modal-description"></div>
    </div>
  </div>
</div>
